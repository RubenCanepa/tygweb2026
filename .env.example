# TMDB API Token - Bearer Token from TMDB Settings -> API
TMDB_API_TOKEN=your_tmdb_bearer_token_here

# Storage Mode (json = local JSON file database, strapi = real Strapi CMS connection)
STORAGE_MODE=json

# Strapi Headless CMS Configuration (Required if STORAGE_MODE=strapi)
STRAPI_API_URL=http://localhost:1337
# STRAPI_API_TOKEN=your_strapi_api_token_here
